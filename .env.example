# NitroStack runtime
NITRO_LOG_LEVEL=info
NITROSTACK_APP_MODE=openai
MCP_TRANSPORT_TYPE=dual
PORT=3000
HOST=localhost
ENABLE_CORS=true

# Free/public testnet RPC endpoints. Use only the chains you want to demo.
BASE_SEPOLIA_RPC_URL=
ETHEREUM_SEPOLIA_RPC_URL=
POLYGON_AMOY_RPC_URL=

# Test-USDC contracts. Always verify these against the issuer's official docs.
BASE_SEPOLIA_USDC_ADDRESS=
ETHEREUM_SEPOLIA_USDC_ADDRESS=
POLYGON_AMOY_USDC_ADDRESS=

# Aave V3 adapters are enabled only when all required values are present.
AAVE_BASE_SEPOLIA_POOL_ADDRESS=
AAVE_DATA_PROVIDER_BASE_SEPOLIA_ADDRESS=
AAVE_ETHEREUM_SEPOLIA_POOL_ADDRESS=
AAVE_DATA_PROVIDER_ETHEREUM_SEPOLIA_ADDRESS=

# Controlled ERC-4626 demo vault. The APY is a labeled demo scenario, not a
# claim about real testnet yield. Deploy contracts/MockYieldVault.sol first.
BASE_SEPOLIA_DEMO_VAULT_ADDRESS=
AMOY_ERC4626_VAULT_ADDRESS=
DEMO_VAULT_APY_BPS=650
DEMO_VAULT_RISK_SCORE=45

# Optional local persistence for hackathon demos. Never stores wallet secrets.
PROOFYIELD_RECEIPT_STORE_PATH=data/receipts.json
